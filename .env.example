# AQELYN runtime configuration (12-factor; see ADR-0001 D9, CONVENTIONS §8)
# Copy to .env for local development. NEVER commit real secrets.

AQELYN_ENV=local                 # local | staging | production
AQELYN_LOG_LEVEL=INFO
AQELYN_TENANT_MODE=local         # local (NULL tenant) | enterprise

# Backing services (used from T2/T3 onward; compose provides these locally)
AQELYN_DATABASE_URL=postgresql+asyncpg://aqelyn:aqelyn@localhost:5432/aqelyn
AQELYN_REDIS_URL=redis://localhost:6379/0

# Values consumed by docker-compose for the Postgres container
POSTGRES_USER=aqelyn
POSTGRES_PASSWORD=aqelyn
POSTGRES_DB=aqelyn
